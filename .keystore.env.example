# Шаблон файла .keystore.env — скопируйте в .keystore.env (gitignored) и заполните.
# Значения не коммитятся. Keystore генерируется командой:
#   keytool -genkey -v -keystore ~/boxmaster-upload-keystore.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias upload

ANDROID_KEYSTORE_PATH=
ANDROID_KEYSTORE_USER=upload
ANDROID_KEYSTORE_PASSWORD=
