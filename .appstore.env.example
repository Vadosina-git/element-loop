# Шаблон файла .appstore.env — скопируйте в .appstore.env (gitignored) и заполните.
# Значения берутся из SHARED_ACCOUNTS_REFERENCE.md (не коммитить).

APP_STORE_ISSUER_ID=
APP_STORE_API_KEY_ID=
APP_STORE_API_KEY_PATH=$HOME/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8
APP_STORE_IAP_KEY_ID=
APP_STORE_IAP_KEY_PATH=$HOME/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8
APP_STORE_APP_APPLE_ID=
APP_STORE_BUNDLE_ID=com.khralz.boxmaster
APP_STORE_SANDBOX_EMAIL=
APP_STORE_SANDBOX_PASSWORD=
